# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: anthropic | openai | ollama  (default: anthropic)
LLM_PROVIDER=anthropic

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override model (default: claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI ────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# Optional: override model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o

# ── Ollama (local) ────────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Twitter/X fetching (optional) ────────────────────────────────────────────
# Required only if you pass Twitter/X URLs as sources
# ADHX_API_KEY=your-adhx-api-key
